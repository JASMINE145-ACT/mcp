# WeChat Official Account
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# OpenAI Article Generation (only needed for main.py generate/draft)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Exa Search (https://exa.ai/api-key)
EXA_API_KEY=

# Tavily Search (https://tavily.com)
TAVILY_API_KEY=

# Cover Image Search (fill in one of the two)
# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=

# Article Defaults
DEFAULT_AUTHOR=2AIBot
DEFAULT_SOURCE_URL=
DEFAULT_COVER_PATH=

# Auto-publish: set to true to allow wechat_publish tool to push drafts to subscribers
# WARNING: publishing is irreversible. Keep false unless you know what you're doing.
ENABLE_AUTO_PUBLISH=false
